function handleTeamLeavesFilterSubmission(payload) {
  const userId = payload.user.id;
  const v = payload.view.state.values;
  const start = v.date_range_start.start_date.selected_date;
  const end   = v.date_range_end.end_date.selected_date;
  if (start > end) return { response_action: "errors", errors: { date_range_end: "Invalid Range" } };
  slackApiFetch("chat.postEphemeral", { channel: userId, user: userId, text: "Calendar", blocks: getTeamLeavesCalendarBlocks(userId, start, end) });
  return { response_action: "clear" };
}

function handleMyLeavesFilterSubmission(payload) {
  const userId = payload.user.id;
  const v = payload.view.state.values;
  const start = v.date_range_start.start_date.selected_date;
  const end   = v.date_range_end.end_date.selected_date;
  slackApiFetch("chat.postEphemeral", { channel: userId, user: userId, text: "My Leaves", blocks: getMyLeavesBlocks(userId, start, end) });
  return { response_action: "clear" };
}

function getMyLeavesBlocks(userId, filterStart, filterEnd) {
  const leaves = getRequestsData().filter(r =>
    r[COL_REQ_SLACK_ID] === userId &&
    toDateString(r[COL_REQ_START_DATE]) <= filterEnd &&
    toDateString(r[COL_REQ_END_DATE])   >= filterStart
  );
  const blocks = [{ type: "header", text: { type: "plain_text", text: "My Leaves" } }];
  if (leaves.length === 0) blocks.push({ type: "section", text: { type: "mrkdwn", text: "No leaves found." } });
  leaves.slice(0, 10).forEach(r => {
    blocks.push({ type: "divider" });
    blocks.push({ type: "section", text: { type: "mrkdwn", text: `*${r[COL_REQ_TYPE]}*\n${toDateString(r[COL_REQ_START_DATE])} ➡ ${toDateString(r[COL_REQ_END_DATE])}\nStatus: *${r[COL_REQ_STATUS]}*` } });
  });
  return blocks;
}

function getTeamLeavesCalendarBlocks(userId, filterStart, filterEnd) {
  const teamIds = Object.keys(_cachedUserMap).filter(id => _cachedUserMap[id].appr === userId);
  const leaves  = getRequestsData().filter(r =>
    teamIds.includes(r[COL_REQ_SLACK_ID]) && r[COL_REQ_STATUS] !== "Rejected" &&
    toDateString(r[COL_REQ_START_DATE]) <= filterEnd &&
    toDateString(r[COL_REQ_END_DATE])   >= filterStart
  );
  const blocks = [{ type: "header", text: { type: "plain_text", text: "Team Calendar" } }];
  if (leaves.length === 0) { blocks.push({ type: "section", text: { type: "mrkdwn", text: "No team leaves found." } }); return blocks; }
  leaves.slice(0, 15).forEach(r => {
    blocks.push({ type: "divider" });
    blocks.push({ type: "section", text: { type: "mrkdwn", text: `*${r[COL_REQ_NAME]}* - ${r[COL_REQ_TYPE]}\n${toDateString(r[COL_REQ_START_DATE])} ➡ ${toDateString(r[COL_REQ_END_DATE])}` } });
  });
  return blocks;
}

// ====================================================================
// === HR TOOLS
// ====================================================================

function openAdminBalanceModal(trigger_id, userId) {
  if (!isHR(userId)) return postSlackMessage(userId, "🚫 Unauthorized.");
  slackApiFetch("views.open", { trigger_id, view: {
    type: "modal", callback_id: "admin_balance_modal",
    title: { type: "plain_text", text: "Adjust Balance" }, submit: { type: "plain_text", text: "Save" },
    blocks: [
      { type: "input", block_id: "user_select",       label: { type: "plain_text", text: "User" },        element: { type: "users_select",    action_id: "user_id" } },
      { type: "input", block_id: "balance_type",      label: { type: "plain_text", text: "Type" },        element: { type: "static_select",   action_id: "type",   options: [{ text: { type: "plain_text", text: "Annual" }, value: "Annual" }, { text: { type: "plain_text", text: "Sick" }, value: "Sick" }] } },
      { type: "input", block_id: "adjustment_amount", label: { type: "plain_text", text: "Amount (+/-)" }, element: { type: "plain_text_input", action_id: "amount" } }
    ]
  }});
}

function handleAdminBalanceSubmission(payload) {
  const v        = payload.view.state.values;
  const actorId  = payload.user.id;
  const targetId = v.user_select.user_id.selected_user;
  const type     = v.balance_type.type.selected_option.value;
  const amount   = parseFloat(v.adjustment_amount.amount.value);

  if (isNaN(amount)) return { response_action: "errors", errors: { adjustment_amount: "Number required" } };

  const idx = getUserRowIndex(targetId);
  if (idx === -1) return { response_action: "errors", errors: { user_select: "User not found" } };

  const col    = type === "Annual" ? COL_USER_ANNUAL_BALANCE + 1 : COL_USER_SICK_BALANCE + 1;
  const cell   = getSheet(SHEET_NAME_USERS).getRange(idx + 1, col);
  const oldBal = cell.getValue();
  const newBal = oldBal + amount;
  cell.setValue(newBal);

  logAuditEntry(actorId, targetId, "BALANCE_ADJUSTED", `HR adjusted ${type} balance by ${amount > 0 ? "+" : ""}${amount}`, String(oldBal), String(newBal));

  CacheService.getScriptCache().remove("USER_MAP_V3");
  _cachedUserMap = null;

  postSlackMessage(actorId,  `✅ Updated ${type} balance for <@${targetId}>: ${oldBal} → *${newBal}*`);
  postSlackMessage(targetId, `ℹ️ Your *${type}* balance was adjusted by HR: ${oldBal} → *${newBal} days*`);
  return { response_action: "clear" };
}

function openPolicyUpdateModal(trigger_id) {
  slackApiFetch("views.open", { trigger_id, view: {
    type: "modal", callback_id: "update_policy_modal",
    title: { type: "plain_text", text: "Policy" }, submit: { type: "plain_text", text: "Update" },
    blocks: [{ type: "input", block_id: "policy_text", label: { type: "plain_text", text: "New Policy" },
      element: { type: "plain_text_input", action_id: "text", multiline: true, initial_value: getCurrentPolicyText() }
    }]
  }});
}

function handlePolicyUpdateSubmission(payload) {
  const actorId = payload.user.id;
  const oldText = getCurrentPolicyText();
  const newText = payload.view.state.values.policy_text.text.value;

  getSheet(SHEET_NAME_POLICY).getRange(POLICY_CELL).setValue(newText);

  // Bust policy cache so home tabs show new text immediately
  CacheService.getScriptCache().remove("POLICY_V1");
  _cachedPolicy = null;

  logAuditEntry(actorId, null, "POLICY_UPDATED", "Leave policy updated.", oldText.substring(0, 100), newText.substring(0, 100));

  postSlackMessage(actorId, "✅ Policy updated.");
  updateSlackHome(actorId);
  return { response_action: "clear" };
}

function openAnnouncementModal(trigger_id) {
  slackApiFetch("views.open", { trigger_id, view: {
    type: "modal", callback_id: "send_announcement_modal",
    title: { type: "plain_text", text: "Announcement" }, submit: { type: "plain_text", text: "Send" },
    blocks: [{ type: "input", block_id: "msg", label: { type: "plain_text", text: "Message" }, element: { type: "plain_text_input", action_id: "text", multiline: true } }]
  }});
}

function handleAnnouncementSubmission(payload) {
  const actorId = payload.user.id;
  const text    = payload.view.state.values.msg.text.value;
  let count     = 0;
  for (const id in _cachedUserMap) { postSlackMessage(id, `:mega: *Announcement:*\n${text}`); count++; }
  logAuditEntry(actorId, null, "ANNOUNCEMENT_SENT", `Sent to ${count} users. Preview: "${text.substring(0, 80)}${text.length > 80 ? "..." : ""}"`);
  postSlackMessage(actorId, `✅ Announcement sent to ${count} users.`);
  return { response_action: "clear" };
}

function openHRReportModal(trigger_id) {
  slackApiFetch("views.open", { trigger_id, view: {
    type: "modal", callback_id: "generate_hr_report",
    title: { type: "plain_text", text: "Report" }, submit: { type: "plain_text", text: "Download" },
    blocks: [
      { type: "input", block_id: "start", label: { type: "plain_text", text: "Start" }, element: { type: "datepicker", action_id: "date" } },
      { type: "input", block_id: "end",   label: { type: "plain_text", text: "End" },   element: { type: "datepicker", action_id: "date" } }
    ]
  }});
}

function handleHRReportSubmission(payload) {
  const actorId  = payload.user.id;
  const start    = payload.view.state.values.start.date.selected_date;
  const end      = payload.view.state.values.end.date.selected_date;
  const filtered = getRequestsData().filter(r => toDateString(r[COL_REQ_START_DATE]) <= end && toDateString(r[COL_REQ_END_DATE]) >= start);

  if (filtered.length === 0) { postSlackMessage(actorId, "No data for selected range."); return { response_action: "clear" }; }

  const file = DriveApp.createFile(`Report_${start}_to_${end}.csv`, filtered.map(r => r.join(",")).join("\n"), MimeType.CSV);
  logAuditEntry(actorId, null, "REPORT_GENERATED", `Report for ${start} → ${end}. ${filtered.length} records.`);
  postSlackMessage(actorId, `✅ Report ready: <${file.getUrl()}|Download> (${filtered.length} records)`);
  return { response_action: "clear" };
}

// ====================================================================
// === MONTHLY BALANCE INCREMENT
// ====================================================================

function incrementMonthlyBalances() {
  const sheet   = getSheet(SHEET_NAME_USERS);
  const range   = sheet.getDataRange();
  const data    = range.getValues();
  let updates   = 0;
  let skipped   = [];

  for (let i = 1; i < data.length; i++) {
    const row     = data[i];
    const slackId = row[COL_USER_SLACK_ID];
    if (!slackId || slackId === "Slack ID") continue;

    const location = String(row[COL_USER_LOCATION] || "").trim().toUpperCase();
    let increment  = 0;

    if      (location === "BGD")      increment = 1.75;
    else if (location === "UEA")      increment = 2.5;
    else if (location === "UAE-TECH") increment = 2.5;
    // Add more: else if (location === "KSA") increment = 2.0;
    else if (location !== "") {
      skipped.push(`${row[COL_USER_NAME]} (location: "${location}")`);
      logAuditEntry("SYSTEM", slackId, "MONTHLY_SKIP_UNKNOWN", `Unknown location "${location}" — skipped.`);
    }

    if (increment > 0) {
      const oldBal = parseFloat(row[COL_USER_ANNUAL_BALANCE]) || 0;
      const newBal = oldBal + increment;
      data[i][COL_USER_ANNUAL_BALANCE] = newBal;
      updates++;

      logAuditEntry("SYSTEM", slackId, "MONTHLY_INCREMENT", `+${increment} days (${location})`, String(oldBal), String(newBal));

      try {
        postSlackMessage(slackId, `💰 *Monthly Update:* Annual Leave balance increased by *+${increment} days*.\nNew Balance: *${newBal} days*`);
        Utilities.sleep(200);
      } catch(e) { Logger.log(`Notify failed for ${slackId}: ${e.message}`); }
    }
  }

  if (updates > 0) {
    range.setValues(data);
    CacheService.getScriptCache().remove("USER_MAP_V3");
    _cachedUserMap = null;
    Logger.log(`✅ Incremented ${updates} users.`);
  } else {
    Logger.log("ℹ️ No eligible users.");
  }

  if (skipped.length > 0) {
    const msg = `⚠️ *Monthly Increment — Skipped (unknown location):*\n` + skipped.map(s => `• ${s}`).join("\n") + `\n\nPlease fix their Location in the Users sheet.`;
    for (const id in _cachedUserMap) {
      if (_cachedUserMap[id].role === "HR") postSlackMessage(id, msg);
    }
  }
}

function diagnoseLocations() {
  if (!_cachedUserMap) loadUserData();
  const summary = {};
  for (const id in _cachedUserMap) {
    const loc = _cachedUserMap[id].loc || "⚠️ BLANK";
    if (!summary[loc]) summary[loc] = [];
    summary[loc].push(_cachedUserMap[id].name);
  }
  let msg = "*📍 Location Diagnostic:*\n\n";
  for (const loc in summary) {
    msg += `*${loc}* (${summary[loc].length} users):\n${summary[loc].map(n => `  • ${n}`).join("\n")}\n\n`;
  }
  Logger.log(msg);
}

// ====================================================================
// === HOME TAB
// ====================================================================

function updateSlackHome(userId) {
  if (!_cachedUserMap) loadUserData();
  const user = _cachedUserMap[userId];
  const pol  = getCurrentPolicyText(); // ← now reads from cache, not sheet

  let hierarchyBlock = { type: "section", text: { type: "mrkdwn", text: "⚠ Hierarchy unavailable (User not found)." } };

  if (user) {
    const m1Id   = user.appr;
    const m1Name = (m1Id && _cachedUserMap[m1Id]) ? _cachedUserMap[m1Id].name : (m1Id ? `<@${m1Id}>` : "None");
    let m2Id = null, m2Name = "None";
    if (m1Id && _cachedUserMap[m1Id]) {
      m2Id   = _cachedUserMap[m1Id].appr;
      m2Name = (m2Id && _cachedUserMap[m2Id]) ? _cachedUserMap[m2Id].name : (m2Id ? `<@${m2Id}>` : "None");
    }
    let m3Id = null, m3Name = "None";
    if (m2Id && _cachedUserMap[m2Id]) {
      m3Id   = _cachedUserMap[m2Id].appr;
      m3Name = (m3Id && _cachedUserMap[m3Id]) ? _cachedUserMap[m3Id].name : (m3Id ? `<@${m3Id}>` : "None");
    }
    hierarchyBlock = { type: "section", text: { type: "mrkdwn", text:
      `*📋 Your Reporting Line:*\n *Direct Manager:* ${m1Name}\n *Level 2 Manager:* ${m2Name}\n *Level 3 Manager:* ${m3Name}`
    }};
  }

  const blocks = [
    { type: "header",  text: { type: "plain_text", text: "Leave Dashboard" } },
    { type: "divider" },
    { type: "section", text: { type: "mrkdwn", text: `*Balance:* 🏖 ${user ? user.balAnn : 0} | 🤒 ${user ? user.balSick : 0}` } },
    { type: "divider" },
    getHomeHolidayBlock(user ? user.loc : "ALL"),
    { type: "divider" },
    hierarchyBlock,
    { type: "divider" },
    { type: "actions", elements: [
      { type: "button", text: { type: "plain_text", text: "Request Leave" }, action_id: "request_leave_home",    style: "primary" },
      { type: "button", text: { type: "plain_text", text: "Remote Work" },   action_id: "working_remotely_home" },
      { type: "button", text: { type: "plain_text", text: "Team Balances" }, action_id: "team_balance_home" }
    ]},
    { type: "actions", elements: [
      { type: "button", text: { type: "plain_text", text: "My Leaves" },   action_id: "my_leaves_home" },
      { type: "button", text: { type: "plain_text", text: "Team Leaves" }, action_id: "team_leaves_home" }
    ]},
    { type: "divider" },
    { type: "context", elements: [{ type: "mrkdwn", text: `*Policy:* ${pol}` }] }
  ];

  if (isHR(userId)) {
    blocks.push({ type: "divider" });
    blocks.push({ type: "header", text: { type: "plain_text", text: "HR Admin" } });
    blocks.push({ type: "actions", elements: [
      { type: "button", text: { type: "plain_text", text: "Adjust Balance" },  action_id: "admin_balances",    style: "danger" },
      { type: "button", text: { type: "plain_text", text: "Report" },          action_id: "hr_reports" },
      { type: "button", text: { type: "plain_text", text: "Policy" },          action_id: "update_policy" },
      { type: "button", text: { type: "plain_text", text: "Announce" },        action_id: "send_announcement" },
      { type: "button", text: { type: "plain_text", text: "🔄 Refresh Data" }, action_id: "refresh_data" }
    ]});
  }

  slackApiFetch("views.publish", { user_id: userId, view: { type: "home", blocks } });
}

// ====================================================================
// === DAILY STATUS CRON JOB
// ====================================================================
// Trigger: Time-driven → Daily at 8:00 AM

function setDailyLeaveStatuses() {
  const data  = getSheet(SHEET_NAME_REQUESTS).getDataRange().getValues();
  const today = new Date(); today.setHours(0, 0, 0, 0);
  let updated = 0;

  for (let i = 1; i < data.length; i++) {
    const row = data[i];
    if (row[COL_REQ_STATUS] !== "Approved") continue;

    const start = new Date(row[COL_REQ_START_DATE]); start.setHours(0, 0, 0, 0);
    const end   = new Date(row[COL_REQ_END_DATE]);   end.setHours(0, 0, 0, 0);

    if (today >= start && today <= end) {
      try {
        updateUserSlackStatus(row[COL_REQ_SLACK_ID], row[COL_REQ_TYPE], row[COL_REQ_END_DATE]);
        logAuditEntry("SYSTEM", row[COL_REQ_SLACK_ID], "DAILY_STATUS_UPDATE",
          `Slack status set to "${row[COL_REQ_TYPE]}" (${toDateString(row[COL_REQ_START_DATE])} → ${toDateString(row[COL_REQ_END_DATE])})`);
        updated++;
        Utilities.sleep(300);
      } catch(e) { Logger.log(`Status update failed for ${row[COL_REQ_SLACK_ID]}: ${e.message}`); }
    }
  }
  Logger.log(`✅ Daily Status Check: updated ${updated} users.`);
}
