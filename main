function openMyLeavesFilterModal(trigger_id) {
  slackApiFetch("views.open", { trigger_id, view: { type: "modal", callback_id: "my_leaves_filter_modal", title: { type: "plain_text", text: "My Leaves" }, submit: { type: "plain_text", text: "View" }, blocks: [
      { type: "input", block_id: "date_range_start", label: { type: "plain_text", text: "Start" }, element: { type: "datepicker", action_id: "start_date" } },
      { type: "input", block_id: "date_range_end", label: { type: "plain_text", text: "End" }, element: { type: "datepicker", action_id: "end_date" } }
  ]}});
}

function handleTeamLeavesFilterSubmission(payload) {
  const userId = payload.user.id;
  const v = payload.view.state.values;
  const start = v.date_range_start.start_date.selected_date;
  const end = v.date_range_end.end_date.selected_date;
  
  if (start > end) return { response_action: "errors", errors: { date_range_end: "Invalid Range" } };

  // Generate blocks in background and send via ephemeral
  const blocks = getTeamLeavesCalendarBlocks(userId, start, end);
  slackApiFetch("chat.postEphemeral", { channel: userId, user: userId, text: "Calendar", blocks });
  return { response_action: "clear" };
}

function handleMyLeavesFilterSubmission(payload) {
   const userId = payload.user.id;
   const v = payload.view.state.values;
   const start = v.date_range_start.start_date.selected_date;
   const end = v.date_range_end.end_date.selected_date;

   const blocks = getMyLeavesBlocks(userId, start, end);
   slackApiFetch("chat.postEphemeral", { channel: userId, user: userId, text: "My Leaves", blocks });
   return { response_action: "clear" };
}

function getMyLeavesBlocks(userId, filterStart, filterEnd) {
    const data = getRequestsData();
    const myLeaves = data.filter(r => r[COL_REQ_SLACK_ID] === userId && toDateString(r[COL_REQ_START_DATE]) <= filterEnd && toDateString(r[COL_REQ_END_DATE]) >= filterStart);
    
    const blocks = [{ type: "header", text: { type: "plain_text", text: "My Leaves" } }];
    if (myLeaves.length === 0) blocks.push({ type: "section", text: { type: "mrkdwn", text: "No leaves found." } });
    
    myLeaves.slice(0, 10).forEach(r => {
        blocks.push({ type: "divider" });
        blocks.push({ type: "section", text: { type: "mrkdwn", text: `*${r[COL_REQ_TYPE]}*\n${toDateString(r[COL_REQ_START_DATE])} ➡ ${toDateString(r[COL_REQ_END_DATE])}\nStatus: *${r[COL_REQ_STATUS]}*` } });
    });
    return blocks;
}

function getTeamLeavesCalendarBlocks(userId, filterStart, filterEnd) {
    const data = getRequestsData();
    if (!_cachedUserMap) loadUserData();
    
    const teamIds = Object.keys(_cachedUserMap).filter(id => _cachedUserMap[id].appr === userId);
    const leaves = data.filter(r => teamIds.includes(r[COL_REQ_SLACK_ID]) && r[COL_REQ_STATUS] !== "Rejected" && toDateString(r[COL_REQ_START_DATE]) <= filterEnd && toDateString(r[COL_REQ_END_DATE]) >= filterStart);

    const blocks = [{ type: "header", text: { type: "plain_text", text: "Team Calendar" } }];
    if (leaves.length === 0) {
        blocks.push({ type: "section", text: { type: "mrkdwn", text: "No team leaves found." } });
        return blocks;
    }

    leaves.slice(0, 15).forEach(r => {
        blocks.push({ type: "divider" });
        blocks.push({ type: "section", text: { type: "mrkdwn", text: `*${r[COL_REQ_NAME]}* - ${r[COL_REQ_TYPE]}\n${toDateString(r[COL_REQ_START_DATE])} ➡ ${toDateString(r[COL_REQ_END_DATE])}` } });
    });
    return blocks;
}

