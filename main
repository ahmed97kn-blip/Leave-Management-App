    slackApiFetch("views.open", { trigger_id, view: { type: "modal", callback_id: "update_policy_modal", title: { type: "plain_text", text: "Policy" }, submit: { type: "plain_text", text: "Update" }, blocks: [
        { type: "input", block_id: "policy_text", label: { type: "plain_text", text: "New Policy" }, element: { type: "plain_text_input", action_id: "text", multiline: true, initial_value: getCurrentPolicyText() } }
    ]}});
}

function handlePolicyUpdateSubmission(payload) {
    const text = payload.view.state.values.policy_text.text.value;
    getSheet(SHEET_NAME_POLICY).getRange(POLICY_CELL).setValue(text);
    postSlackMessage(payload.user.id, "Policy updated.");
    updateSlackHome(payload.user.id);
    return { response_action: "clear" };
}

function openAnnouncementModal(trigger_id) {
    slackApiFetch("views.open", { trigger_id, view: { type: "modal", callback_id: "send_announcement_modal", title: { type: "plain_text", text: "Announcement" }, submit: { type: "plain_text", text: "Send" }, blocks: [
        { type: "input", block_id: "msg", label: { type: "plain_text", text: "Message" }, element: { type: "plain_text_input", action_id: "text", multiline: true } }
    ]}});
}

function handleAnnouncementSubmission(payload) {
    const text = payload.view.state.values.msg.text.value;
    if (!_cachedUserMap) loadUserData();
    let count = 0;
    for (const id in _cachedUserMap) {
        postSlackMessage(id, `:mega: *Announcement:*\n${text}`);
        count++;
    }
    postSlackMessage(payload.user.id, `Sent to ${count} users.`);
    return { response_action: "clear" };
}

function openHRReportModal(trigger_id) {
    slackApiFetch("views.open", { trigger_id, view: { type: "modal", callback_id: "generate_hr_report", title: { type: "plain_text", text: "Report" }, submit: { type: "plain_text", text: "Download" }, blocks: [
        { type: "input", block_id: "start", label: { type: "plain_text", text: "Start" }, element: { type: "datepicker", action_id: "date" } },
        { type: "input", block_id: "end", label: { type: "plain_text", text: "End" }, element: { type: "datepicker", action_id: "date" } }
    ]}});
}

function handleHRReportSubmission(payload) {
    const start = payload.view.state.values.start.date.selected_date;
    const end = payload.view.state.values.end.date.selected_date;
    
    const data = getRequestsData();
    const filtered = data.filter(r => toDateString(r[COL_REQ_START_DATE]) <= end && toDateString(r[COL_REQ_END_DATE]) >= start);
    
    if (filtered.length === 0) { postSlackMessage(payload.user.id, "No data."); return { response_action: "clear" }; }

    const csv = filtered.map(r => r.join(",")).join("\n");
    const file = DriveApp.createFile(`Report_${start}.csv`, csv, MimeType.CSV);
    postSlackMessage(payload.user.id, `Report: <${file.getUrl()}|Download>`);
    return { response_action: "clear" };
}

// ====================================================================
// === 🗓 AUTOMATIC MONTHLY BALANCE INCREMENT ===
// ====================================================================

function incrementMonthlyBalances() {
  const sheet = getSheet(SHEET_NAME_USERS);
  const range = sheet.getDataRange();
  const data = range.getValues();
  let updates = 0;

  // Start loop at 1 to skip the Header row
  for (let i = 1; i < data.length; i++) {
    const row = data[i];
    const slackId = row[COL_USER_SLACK_ID];
    
    if (!slackId || slackId === "Slack ID") continue;

    const location = String(row[COL_USER_LOCATION] || "").trim().toUpperCase();
    let increment = 0;
    
    if (location === "BGD") { increment = 1.75; } 
    else if (location === "UEA") { increment = 2.5; }
    
    if (increment > 0) {
       const currentBalance = parseFloat(row[COL_USER_ANNUAL_BALANCE]) || 0;
       const newBalance = currentBalance + increment;
       
       data[i][COL_USER_ANNUAL_BALANCE] = newBalance;
       updates++;

       try {
           const msg = `💰 *Monthly Update:* Your Annual Leave balance has increased by *+${increment} days*.\nNew Balance: *${newBalance}*`;
           postSlackMessage(slackId, msg);
           Utilities.sleep(200); 
       } catch (e) {
           Logger.log(`Failed to notify ${slackId}: ${e.message}`);
       }
    }
  }

  if (updates > 0) {
      range.setValues(data);
      CacheService.getScriptCache().remove("USER_MAP_V3");
      _cachedUserMap = null;
      logAuditEntry("SYSTEM", "ALL", "MONTHLY_INCREMENT", `Updated balances for ${updates} users.`);
      Logger.log(`✅ Successfully incremented balances and notified ${updates} users.`);
  } else {
      Logger.log("ℹ No eligible users found for increment.");
  }
}

// ====================================================================
// === 🏠 HOME TAB WITH HIERARCHY ===
// ====================================================================

function updateSlackHome(userId) {
  // 1. Ensure Data is Loaded
  if (!_cachedUserMap) loadUserData();
  const user = _cachedUserMap[userId];
  const pol = getCurrentPolicyText();
  
  // 2. 🌳 Calculate Hierarchy Tree
  let hierarchyBlock = { type: "section", text: { type: "mrkdwn", text: "⚠ Hierarchy unavailable (User not found)." } };
  
  if (user) {
      // Level 1: Direct Manager
      const m1Id = user.appr;
      // We try to get the Name from cache; if not found, we use the Slack ID tag
      const m1Name = (m1Id && _cachedUserMap[m1Id]) ? _cachedUserMap[m1Id].name : (m1Id ? `<@${m1Id}>` : "None");
      
      // Level 2: Manager's Manager
      let m2Id = null;
      let m2Name = "None";
      if (m1Id && _cachedUserMap[m1Id]) {
          m2Id = _cachedUserMap[m1Id].appr; // Look up L1's approver
          if (m2Id && _cachedUserMap[m2Id]) m2Name = _cachedUserMap[m2Id].name;
          else if (m2Id) m2Name = `<@${m2Id}>`;
      }

      // Level 3: Manager's Manager's Manager
      let m3Id = null;
      let m3Name = "None";
      if (m2Id && _cachedUserMap[m2Id]) {
          m3Id = _cachedUserMap[m2Id].appr; // Look up L2's approver
          if (m3Id && _cachedUserMap[m3Id]) m3Name = _cachedUserMap[m3Id].name;
          else if (m3Id) m3Name = `<@${m3Id}>`;
      }
      
      const treeText = `*📋 Your Reporting Line:*\n` +
                       ` *Direct Manager:* ${m1Name}\n` +
                       ` *Level 2 Manager:* ${m2Name}\n` +
                       ` *Level 3 Manager:* ${m3Name}`;

      hierarchyBlock = { type: "section", text: { type: "mrkdwn", text: treeText } };
  }

  // 3. Construct the View Blocks
  const blocks = [
     { type: "header", text: { type: "plain_text", text: "Leave Dashboard" } },
     { type: "divider" },
     // Balance Section
     { type: "section", text: { type: "mrkdwn", text: `*Balance:* 🏖 ${user ? user.balAnn : 0} | 🤒 ${user ? user.balSick : 0}` } },
     
     // 🌳 NEW HIERARCHY SECTION ADDED HERE 🌳
     { type: "divider" },
     hierarchyBlock,
     { type: "divider" },

     // Action Buttons
     { type: "actions", elements: [
        { type: "button", text: { type: "plain_text", text: "Request Leave" }, action_id: "request_leave_home", style: "primary" },
        { type: "button", text: { type: "plain_text", text: "Remote Work" }, action_id: "working_remotely_home" },
        { type: "button", text: { type: "plain_text", text: "Team Balances" }, action_id: "team_balance_home" }
     ]},
     { type: "actions", elements: [
        { type: "button", text: { type: "plain_text", text: "My Leaves" }, action_id: "my_leaves_home" },
        { type: "button", text: { type: "plain_text", text: "Team Leaves" }, action_id: "team_leaves_home" }
     ]},
     { type: "divider" },
     { type: "context", elements: [{ type: "mrkdwn", text: `*Policy:* ${pol}` }] }
  ];
  
  // HR Tools (Only visible to HR)
  if (isHR(userId)) {
      blocks.push({ type: "divider" }, { type: "header", text: { type: "plain_text", text: "HR Admin" } });
      blocks.push({ type: "actions", elements: [
          { type: "button", text: { type: "plain_text", text: "Adjust Balance" }, action_id: "admin_balances", style: "danger" },
          { type: "button", text: { type: "plain_text", text: "Report" }, action_id: "hr_reports" },
          { type: "button", text: { type: "plain_text", text: "Policy" }, action_id: "update_policy" },
          { type: "button", text: { type: "plain_text", text: "Announce" }, action_id: "send_announcement" },
          { type: "button", text: { type: "plain_text", text: "🔄 Refresh Data" }, action_id: "refresh_data" }
      ]});
  }
  
  slackApiFetch("views.publish", { user_id: userId, view: { type: "home", blocks } });
}

// ====================================================================
// === ⏰ DAILY STATUS CRON JOB (NEW) ===
// ====================================================================

/**
 * ⚡ IMPORTANT: Set a "Time-driven" trigger for this function.
 * Recommended: Daily at 8:00 AM.
 */
function setDailyLeaveStatuses() {
  const sheet = getSheet(SHEET_NAME_REQUESTS);
  const data = sheet.getDataRange().getValues(); // Get fresh data
  const today = new Date();
  today.setHours(0, 0, 0, 0);

  let updatesCount = 0;

  // Start at 1 to skip header
  for (let i = 1; i < data.length; i++) {
    const row = data[i];
    
    // Check if Status is APPROVED
    if (row[COL_REQ_STATUS] !== "Approved") continue;

    const slackId = row[COL_REQ_SLACK_ID];
    const type = row[COL_REQ_TYPE];
    
    // Parse Dates
    const start = new Date(row[COL_REQ_START_DATE]);
    const end = new Date(row[COL_REQ_END_DATE]);
    start.setHours(0,0,0,0);
    end.setHours(0,0,0,0);

    // Check if TODAY is inside the leave period
    if (today.getTime() >= start.getTime() && today.getTime() <= end.getTime()) {
        try {
            updateUserSlackStatus(slackId, type, row[COL_REQ_END_DATE]);
            updatesCount++;
            // Sleep briefly to prevent hitting Slack API rate limits
            Utilities.sleep(300); 
        } catch (e) {
            Logger.log(`Error updating status for ${slackId}: ${e.message}`);
        }
    }
  }
  Logger.log(`✅ Daily Status Check: Updated status for ${updatesCount} users.`);
}
